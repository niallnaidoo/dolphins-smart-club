{
  "name": "dolphins-smart-club",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "description": "Hollywoodbets Dolphins Smart Club Integration Platform — clickable prototype",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx,ts,tsx",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "sst deploy --stage prod",
    "deploy:dev": "sst deploy --stage dev",
    "deploy:remove": "sst remove --stage dev",
    "dev:sst": "sst dev",
    "dev:local": "concurrently -k -n api,web -c blue,green \"npm --prefix packages/api run dev:local\" \"vite\"",
    "dev:local:demo": "concurrently -k -n api,web -c blue,green \"SEED_DEMO=1 npm --prefix packages/api run dev:local\" \"vite\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "aws-amplify": "^6.6.0",
    "exceljs": "^4.4.0",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.1.2",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.4.2",
    "sst": "^3.7.15",
    "typescript": "^5.9.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
