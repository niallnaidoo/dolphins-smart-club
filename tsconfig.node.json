{
  /*
   * Node-context build/config files (vite.config.ts). Checked via:
   *   tsc --noEmit -p tsconfig.node.json
   * sst.config.ts is intentionally NOT included here — it keeps the root tsconfig.json
   * (which carries its .sst/platform ambient globals and load-bearing @ts-expect-error).
   */
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],

    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,

    "allowJs": true,
    "strict": true
  },
  "include": ["vite.config.ts"]
}
